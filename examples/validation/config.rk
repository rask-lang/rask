// Server configuration, shared read-heavy across all request tasks.

import os

// Every field defaulted, so `Config {}` constructs the default config and
// from_env() only overrides what the environment sets.

struct Config {
    public host: string = "0.0.0.0"
    public port: u16 = 8080
    public store_capacity: usize = 10000
    public rate_limit_per_min: u64 = 120
    public request_log: bool = true
}

extend Config {
    func from_env() -> Config {
        mut c = Config {}
        c.host = os.env_or("TRACKER_HOST", c.host)
        c.port = parse_port(os.env("TRACKER_PORT")) ?? c.port
        return c
    }

    func addr(self) -> string {
        return "{self.host}:{self.port}"
    }
}

// Public conformance — the config's Displayable rendering is part of the
// service's observable API (it lands in startup logs).
public extend Config with Displayable {
    func to_string(self) -> string {
        return "Config(addr={self.addr()}, cap={self.store_capacity}, rate={self.rate_limit_per_min}/min)"
    }
}

func parse_port(raw: string?) -> u16? {
    const s = raw ?? return none
    const n = s.parse<u16>() ?? return none
    return n
}

// Read-heavy shared state (conc.sync SY1): many request tasks read it,
// writes are rare (reload). Module-level const — Shared owns the interior.
const config = Shared.new(Config.from_env())
