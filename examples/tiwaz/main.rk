import http

func main() -> () or Error {
    using Multitasking {
        const server = try http.HttpServer.listen("0.0.0.0:8080")
        ensure server.close()
        println("listening on 8080")
        loop {
            println("waiting for request")
            const (request, responder) = try server.accept()
            println("got request")
            responder.respond(http.Response.ok("Hello from Tiwaz!"))
            println("responded")
        }
    }
}
