


func match_route(path: string, routes: Vec<Route>) -> Route? {
    for route in routes {
        if route is Some(r) {
            if path.starts_with(r.prefix) {
                // Strip the prefix before forwarding to upstream.
                const path = path.slice(r.prefix.len()..)
                return Some(Route { prefix: path, upstream: r.upstream })
            }
        }
    }
    return None
}