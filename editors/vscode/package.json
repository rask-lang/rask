{
  "name": "rask",
  "displayName": "Rask",
  "description": "Language support for Rask",
  "version": "0.2.1",
  "publisher": "rask-lang",
  "license": "MIT OR Apache-2.0",
  "icon": "icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/rask-lang/rask"
  },
  "engines": {
    "vscode": "^1.75.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "activationEvents": [
    "onLanguage:rask"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "rask",
        "aliases": [
          "Rask",
          "rask"
        ],
        "extensions": [
          ".rk"
        ],
        "configuration": "./language-configuration.json",
        "icon": {
          "light": "./icons/rask-file.svg",
          "dark": "./icons/rask-file.svg"
        }
      }
    ],
    "grammars": [
      {
        "language": "rask",
        "scopeName": "source.rk",
        "path": "./syntaxes/rask.tmLanguage.json"
      },
      {
        "scopeName": "text.markdown.rk.codeblock",
        "path": "./syntaxes/rask-markdown.tmLanguage.json",
        "injectTo": [
          "text.html.markdown"
        ],
        "embeddedLanguages": {
          "meta.embedded.block.rk": "rask"
        }
      }
    ],
    "commands": [
      {
        "command": "rask.run",
        "title": "Rask: Run File",
        "icon": "$(play)"
      },
      {
        "command": "rask.check",
        "title": "Rask: Check File"
      },
      {
        "command": "rask.test",
        "title": "Rask: Run Tests"
      },
      {
        "command": "rask.build",
        "title": "Rask: Build Package"
      },
      {
        "command": "rask.restartServer",
        "title": "Rask: Restart Language Server"
      },
      {
        "command": "rask.showOutput",
        "title": "Rask: Show Language Server Output"
      }
    ],
    "snippets": [
      {
        "language": "rask",
        "path": "./snippets/rask.json"
      }
    ],
    "menus": {
      "editor/title/run": [
        {
          "command": "rask.run",
          "when": "resourceLangId == rask",
          "group": "navigation"
        }
      ]
    },
    "configuration": {
      "type": "object",
      "title": "Rask",
      "properties": {
        "rask.serverPath": {
          "type": "string",
          "default": "",
          "description": "Path to rask-lsp binary. If empty, searches PATH."
        },
        "rask.cliPath": {
          "type": "string",
          "default": "",
          "description": "Path to the rask CLI binary (used by Run/Check/Test/Build). If empty, searches next to serverPath and PATH."
        },
        "rask.inlayHints.enable": {
          "type": "boolean",
          "default": true,
          "description": "Show inferred types as inlay hints on `mut`/`const` bindings."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "package": "npm run check-types && node esbuild.js --production",
    "compile": "npm run check-types && node esbuild.js",
    "watch": "node esbuild.js --watch",
    "check-types": "tsc --noEmit -p ./"
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.75.0",
    "esbuild": "^0.25.12",
    "typescript": "^5.0.0"
  }
}
