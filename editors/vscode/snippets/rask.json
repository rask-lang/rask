{
  "Function": {
    "prefix": "func",
    "body": [
      "func ${1:name}(${2:params}) -> ${3:ReturnType} {",
      "\t$0",
      "}"
    ],
    "description": "Function declaration"
  },
  "Struct": {
    "prefix": "struct",
    "body": [
      "struct ${1:Name} {",
      "\t${2:field}: ${3:Type},",
      "}"
    ],
    "description": "Struct declaration"
  },
  "Enum": {
    "prefix": "enum",
    "body": [
      "enum ${1:Name} {",
      "\t${2:Variant},",
      "}"
    ],
    "description": "Enum declaration"
  },
  "Extend": {
    "prefix": "extend",
    "body": [
      "extend ${1:Type} {",
      "\tfunc ${2:method}(self${3}) -> ${4:ReturnType} {",
      "\t\t$0",
      "\t}",
      "}"
    ],
    "description": "Method block"
  },
  "Match": {
    "prefix": "match",
    "body": [
      "match ${1:value} {",
      "\t${2:Pattern} => ${3:expr},",
      "}"
    ],
    "description": "Match expression"
  },
  "For loop": {
    "prefix": "for",
    "body": [
      "for ${1:item} in ${2:iter} {",
      "\t$0",
      "}"
    ],
    "description": "For loop"
  },
  "If present (narrow)": {
    "prefix": "ifq",
    "body": [
      "if ${1:value}? { ${2:expr} }"
    ],
    "description": "Narrow T? / T or E: use scrutinee as T in the then-branch"
  },
  "If present (bind)": {
    "prefix": "ifqas",
    "body": [
      "if ${1:value}? as ${2:v} { ${3:expr} }"
    ],
    "description": "Narrow and bind the present value"
  },
  "Guard absent": {
    "prefix": "guard",
    "body": [
      "if ${1:value} == none { return none }"
    ],
    "description": "Early-exit guard; scrutinee narrows to T after"
  },
  "Test": {
    "prefix": "test",
    "body": [
      "test \"${1:description}\" {",
      "\t$0",
      "}"
    ],
    "description": "Test block"
  },
  "Trait": {
    "prefix": "trait",
    "body": [
      "trait ${1:Name} {",
      "\tfunc ${2:method}(self${3}) -> ${4:ReturnType}",
      "}"
    ],
    "description": "Trait declaration"
  }
}
