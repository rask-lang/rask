// SPDX-License-Identifier: (MIT OR Apache-2.0)
// Native trait-object dispatch (task 1.4, issue #194).
//
// `Shape` declares an incompatible method (`duplicate` returns Self, TR2)
// BEFORE the compatible ones. The vtable holds slots for compatible methods
// only, so `area`/`name` sit at slots 0/1 — not 1/2. MIR dispatch must index
// the same compatible-only list. If the two disagree, calls land on the wrong
// slot and this miscompiles. The interpreter's by-name dispatch masks the bug,
// so this has to run as a compiled binary.

trait Shape {
    func duplicate(self) -> Self       // TR2-incompatible, declared first
    func area(self) -> i64
    func name(self) -> string
}

struct Square {
    side: i64
}

struct Circle {
    radius: i64
}

extend Square with Shape {
    func duplicate(self) -> Square {
        return Square { side: self.side }
    }
    func area(self) -> i64 {
        return self.side * self.side
    }
    func name(self) -> string {
        return "square"
    }
}

extend Circle with Shape {
    func duplicate(self) -> Circle {
        return Circle { radius: self.radius }
    }
    func area(self) -> i64 {
        return 3 * self.radius * self.radius
    }
    func name(self) -> string {
        return "circle"
    }
}

func describe(s: any Shape) -> string {
    return "{s.name()}={s.area()}"
}

func main() {
    const sq = Square { side: 4 }
    const ci = Circle { radius: 5 }
    println(describe(sq as any Shape))
    println(describe(ci as any Shape))
}
