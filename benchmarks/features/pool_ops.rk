benchmark "pool insert+get 10k" {
    mut p = Pool.new()
    mut last = 0
    mut i = 0
    while i < 10000 {
        last = p.insert(i)
        i = i + 1
    }
}

benchmark "pool insert+remove 10k" {
    mut p = Pool.new()
    mut i = 0
    while i < 10000 {
        mut h = p.insert(i)
        p.remove(h)
        i = i + 1
    }
}
