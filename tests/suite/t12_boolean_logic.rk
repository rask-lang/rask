// Boolean operators, short-circuit evaluation.

test "and" {
    assert (true && true) == true
    assert (true && false) == false
    assert (false && true) == false
    assert (false && false) == false
}

test "or" {
    assert (true || true) == true
    assert (true || false) == true
    assert (false || true) == true
    assert (false || false) == false
}

test "not" {
    assert !false == true
    assert !true == false
    assert !!true == true
}

test "combined" {
    assert (true && true) || false
    assert !(false && true)
    assert (5 > 3) && (10 < 20)
    assert (5 > 3) || (10 > 20)
}

test "comparison chains" {
    const x = 5
    assert x > 0 && x < 10
    assert !(x > 0 && x < 3)
    assert x == 5 || x == 6
    assert !(x == 3 || x == 4)
}

// --- Short-circuit verification (BL1) ---
// && and || must not evaluate the right-hand side when the result
// is already determined by the left-hand side.
// Uses a Vec as a side-effect witness — push is observable via len().

func side_effect(mutate witness: Vec<i32>) -> bool {
    witness.push(1)
    return true
}

test "and short-circuits on false" {
    mut w = Vec<i32>.new()
    const result = false && side_effect(w)
    assert !result
    assert w.len() == 0, "right side should not be evaluated"
}

test "or short-circuits on true" {
    mut w = Vec<i32>.new()
    const result = true || side_effect(w)
    assert result
    assert w.len() == 0, "right side should not be evaluated"
}

test "and evaluates right when left is true" {
    mut w = Vec<i32>.new()
    const result = true && side_effect(w)
    assert result
    assert w.len() == 1
}

test "or evaluates right when left is false" {
    mut w = Vec<i32>.new()
    const result = false || side_effect(w)
    assert result
    assert w.len() == 1
}

func main() {}
