// SPDX-License-Identifier: (MIT OR Apache-2.0)
// Vec operations: push, pop, index, length, iteration.

test "vec push and len" {
    mut v = Vec.new()
    assert v.len() == 0
    v.push(1)
    assert v.len() == 1
    v.push(2)
    v.push(3)
    assert v.len() == 3
}

test "vec index access" {
    mut v = Vec.new()
    v.push(10)
    v.push(20)
    v.push(30)
    assert v[0] == 10
    assert v[1] == 20
    assert v[2] == 30
}

test "vec index assign" {
    mut v = Vec.new()
    v.push(1)
    v.push(2)
    v[0] = 99
    assert v[0] == 99
    assert v[1] == 2
}

test "vec pop" {
    mut v = Vec.new()
    v.push(10)
    v.push(20)
    const popped = v.pop()
    assert popped! == 20
    assert v.len() == 1
    assert v[0] == 10
}

test "vec pop empty" {
    mut v = Vec<i32>.new()
    const popped = v.pop()
    assert popped == none
}

test "vec sum via loop" {
    mut v = Vec.new()
    v.push(1)
    v.push(2)
    v.push(3)
    v.push(4)
    v.push(5)
    mut sum = 0
    for i in 0..v.len() {
        sum += v[i]
    }
    assert sum == 15
}

test "vec of strings" {
    mut v = Vec.new()
    v.push("hello")
    v.push("world")
    assert v.len() == 2
    assert v[0] == "hello"
    assert v[1] == "world"
}

test "vec string read twice" {
    mut v = Vec.new()
    v.push("test")
    const a = v[0]
    const b = v[0]
    assert a == "test"
    assert b == "test"
}

test "vec get returns option" {
    mut v = Vec.new()
    v.push(42)
    assert v.get(0)?
    assert v.get(0)! == 42
    assert v.get(99) == none
}

// ─── Vec.get() over f64 / string — Track 1.6 ─────────────────────
// Bug: native `Vec<f64>.get(i)!` hit a Cranelift verifier error
// ("load.i8 <f64>"). `.get()` mapped to the panic-on-OOB runtime that
// returns a raw element, so it never produced a real Option — the `!`
// unwrap then read that f64 as an Option pointer. Now `.get()` returns
// T? (V3: none on OOB, no panic), matching the interpreter and spec.
// Regression source: examples/sensor_processor.rk.

test "vec f64 get unwrap and none" {
    mut v: Vec<f64> = Vec.new()
    v.push(1.5)
    v.push(2.5)
    assert v.get(0)! == 1.5
    assert v.get(1)! == 2.5
    assert v.get(9) == none
}

test "vec string get unwrap and none" {
    mut v: Vec<string> = Vec.new()
    v.push("hi")
    assert v.get(0)! == "hi"
    assert v.get(9) == none
}

// Struct method summing Vec<f64> elements via `.get(i)!` in a loop —
// the exact shape that miscompiled in sensor_processor.
struct Averager {
    samples: Vec<f64>
    count: i64
}

extend Averager {
    func mean(self) -> f64 {
        mut sum = 0.0
        for i in 0..self.count {
            sum += self.samples.get(i)!
        }
        return sum / (self.count as f64)
    }
}

test "struct method averages Vec<f64> via get unwrap" {
    mut s = Vec.new()
    s.push(2.0)
    s.push(4.0)
    s.push(6.0)
    const a = Averager { samples: s, count: 3 }
    assert a.mean() == 4.0
}

// The Option payload sizes the result slot, so the element type must come
// from the checker (`T?`), not from push-tracking — a Vec built in a callee
// has no local push to track. A wrong (i64-sized) slot smashed the stack.
func make_names() -> Vec<string> {
    mut v = Vec.new()
    v.push("alpha")
    v.push("beta")
    return v
}

test "get on Vec<string> returned from a callee (untracked element)" {
    const v = make_names()
    assert v.get(1)! == "beta"
    assert v.get(9) == none
}

func main() {}
