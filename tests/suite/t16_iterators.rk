// Iterators: for-in on collections, range iteration.
// Spec: type.iterator-protocol

// --- Range iteration (always works) ---

test "for range basic" {
    mut sum = 0
    for i in 0..5 {
        sum = sum + i
    }
    assert sum == 10
}

test "for range with variable bounds" {
    const start = 2
    const end = 6
    mut sum = 0
    for i in start..end {
        sum = sum + i
    }
    assert sum == 14
}

test "for range empty when start >= end" {
    mut count = 0
    for i in 5..5 {
        count = count + 1
    }
    assert count == 0
}

test "for range single element" {
    mut count = 0
    for i in 3..4 {
        count = count + 1
        assert i == 3
    }
    assert count == 1
}

// --- For-in on Vec ---
// BUG: Vec indexing returns garbage in native codegen, so for-in
// on Vec also produces wrong values natively.

test "for-in vec sums elements" {
    mut v = Vec<i32>.new()
    v.push(1)
    v.push(2)
    v.push(3)
    mut sum = 0
    for item in v {
        sum = sum + item
    }
    assert sum == 6
}

test "for-in vec counts elements" {
    mut v = Vec<i32>.new()
    v.push(10)
    v.push(20)
    mut count = 0
    for item in v {
        count = count + 1
    }
    assert count == 2
}

test "for-in empty vec" {
    mut v = Vec<i32>.new()
    mut count = 0
    for item in v {
        count = count + 1
    }
    assert count == 0
}

// --- Range-based Vec access (workaround for for-in bug) ---

test "range-based vec iteration" {
    mut v = Vec<i32>.new()
    v.push(10)
    v.push(20)
    v.push(30)
    mut sum = 0
    for i in 0..v.len() {
        sum = sum + v[i]
    }
    assert sum == 60
}

// --- Nested loops ---

test "nested range loops" {
    mut sum = 0
    for i in 0..3 {
        for j in 0..3 {
            sum = sum + 1
        }
    }
    assert sum == 9
}

func main() {}
