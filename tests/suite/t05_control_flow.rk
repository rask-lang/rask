// if/else, loops, break, continue, early return.

func classify(n: i32) -> string {
    if n > 0 {
        return "positive"
    } else if n == 0 {
        return "zero"
    } else {
        return "negative"
    }
}

func abs(n: i32) -> i32 {
    if n < 0 { return -n }
    return n
}

func sum_range(start: i32, end: i32) -> i32 {
    mut total = 0
    for i in start..end {
        total += i
    }
    return total
}

test "if-else" {
    assert classify(5) == "positive"
    assert classify(0) == "zero"
    assert classify(-3) == "negative"
}

test "nested if" {
    const x = 42
    mut result = ""
    if x > 0 {
        if x > 100 {
            result = "big"
        } else {
            result = "small positive"
        }
    } else {
        result = "non-positive"
    }
    assert result == "small positive"
}

test "for range loop" {
    assert sum_range(0, 5) == 10
    assert sum_range(1, 4) == 6
    assert sum_range(0, 0) == 0
    assert sum_range(0, 1) == 0
}

test "while loop" {
    mut n = 0
    mut sum = 0
    while n < 10 {
        sum += n
        n += 1
    }
    assert sum == 45
    assert n == 10
}

test "break in while" {
    mut i = 0
    while true {
        if i == 5 { break }
        i += 1
    }
    assert i == 5
}

test "continue in for" {
    mut sum = 0
    for i in 0..10 {
        if i % 2 == 0 { continue }
        sum += i
    }
    // sum of odds 1+3+5+7+9 = 25
    assert sum == 25
}

test "early return" {
    assert abs(5) == 5
    assert abs(-5) == 5
    assert abs(0) == 0
}

test "multiple return paths" {
    mut x = 10
    if x > 5 {
        assert true
    } else {
        assert false, "should not reach"
    }
}

func main() {}
